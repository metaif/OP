# Target Platform
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# KVM/Virtualization (VirtIO)
CONFIG_PACKAGE_kmod-virtio-net=y
CONFIG_PACKAGE_kmod-virtio-blk=y
CONFIG_PACKAGE_kmod-virtio-balloon=y
CONFIG_PACKAGE_qemu-ga=y

# Image Formats (EFI support)
CONFIG_QCOW2_IMAGES=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=512

# Proxy & Acceleration
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-app-daed-next=y
CONFIG_PACKAGE_kmod-ebpf=y
CONFIG_PACKAGE_kmod-tcp-bbr=y

# Intranet Penetration
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-app-tailscale=y
CONFIG_PACKAGE_luci-app-zerotier=y
CONFIG_PACKAGE_luci-app-easytier=y
CONFIG_PACKAGE_luci-app-cloudflared=y

# Ad Filtering & IPv6
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_odhcpd-ipv6only=y

# VPN & Utils
CONFIG_PACKAGE_luci-app-openvpn=y
CONFIG_PACKAGE_openvpn-openssl=y
CONFIG_PACKAGE_easy-rsa=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_dnsmasq-full=y

# Language & Themes
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_LUCI_LANG_en=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-theme-design=y
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# Hardware Support (NAS & CPU)
CONFIG_PACKAGE_kmod-nvme=y
CONFIG_PACKAGE_kmod-ata-ahci=y
CONFIG_PACKAGE_intel-microcode=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_luci-app-cpufreq=y

# Utils Support
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_coreutils=y
